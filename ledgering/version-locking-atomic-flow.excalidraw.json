      "link": null,
      "locked": false,
      "text": "BEGIN;\n\nDO $$\nDECLARE\n  v_expected_version bigint := 12;\n  v_tx_id text := 'tx_hold_vlock_1001';\n  v_entry_debit_id text := 'entry_vlock_1001_debit';\n  v_entry_credit_id text := 'entry_vlock_1001_credit';\nBEGIN\n  /*\n    Step 1: compare-and-swap on current_version.\n    Chỉ 1 transaction được phép đổi version 12 -> 13.\n  */\n  UPDATE account_current_balances\n  SET\n    current_version = current_version + 1,\n    pending_debits = pending_debits + 70,\n    updated_at = NOW()\n  WHERE account_id = 'alice_wallet'\n    AND current_version = v_expected_version;\n\n  IF NOT FOUND THEN\n    RAISE EXCEPTION\n      'version_lock_failed: expected version % for alice_wallet',\n      v_expected_version;\n  END IF;\n\n  /*\n    Counterparty account cho hold.\n    Ví dụ: partner_payout_holding nhận pending credit.\n  */\n  UPDATE account_current_balances\n  SET\n    pending_credits = pending_credits + 70,\n    current_version = current_version + 1,\n    updated_at = NOW()\n  WHERE account_id = 'partner_payout_holding';\n\n  IF NOT FOUND THEN\n    RAISE EXCEPTION\n      'missing_balance_row: partner_payout_holding';\n  END IF;\n\n  /*\n    Step 2: write ledger transaction + entries.\n    Nếu fail ở đây, cả version bump lẫn balance update đều rollback.\n  */\n  INSERT INTO ledger_transactions (\n    transaction_id,\n    transaction_type,\n    status,\n    effective_at,\n    created_at,\n    reference_type,\n    reference_id\n  )\n  VALUES (\n    v_tx_id,\n    'cash_out_hold',\n    'pending',\n    NOW(),\n    NOW(),\n    'payment_order',\n    'po_1001'\n  );\n\n  INSERT INTO ledger_entries (\n    entry_id,\n    transaction_id,\n    account_id,\n    direction,\n    status,\n    amount,\n    currency,\n    effective_at,\n    created_at\n  )\n  VALUES\n    (\n      v_entry_debit_id,\n      v_tx_id,\n      'alice_wallet',\n      'debit',\n      'pending',\n      70,\n      'USD',\n      NOW(),\n      NOW()\n    ),\n    (\n      v_entry_credit_id,\n      v_tx_id,\n      'partner_payout_holding',\n      'credit',\n      'pending',\n      70,\n      'USD',\n      NOW(),\n      NOW()\n    );\n\nEND $$;\n\nCOMMIT;\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "BEGIN;\n\nDO $$\nDECLARE\n  v_expected_version bigint := 12;\n  v_tx_id text := 'tx_hold_vlock_1001';\n  v_entry_debit_id text := 'entry_vlock_1001_debit';\n  v_entry_credit_id text := 'entry_vlock_1001_credit';\nBEGIN\n  /*\n    Step 1: compare-and-swap on current_version.\n    Chỉ 1 transaction được phép đổi version 12 -> 13.\n  */\n  UPDATE account_current_balances\n  SET\n    current_version = current_version + 1,\n    pending_debits = pending_debits + 70,\n    updated_at = NOW()\n  WHERE account_id = 'alice_wallet'\n    AND current_version = v_expected_version;\n\n  IF NOT FOUND THEN\n    RAISE EXCEPTION\n      'version_lock_failed: expected version % for alice_wallet',\n      v_expected_version;\n  END IF;\n\n  /*\n    Counterparty account cho hold.\n    Ví dụ: partner_payout_holding nhận pending credit.\n  */\n  UPDATE account_current_balances\n  SET\n    pending_credits = pending_credits + 70,\n    current_version = current_version + 1,\n    updated_at = NOW()\n  WHERE account_id = 'partner_payout_holding';\n\n  IF NOT FOUND THEN\n    RAISE EXCEPTION\n      'missing_balance_row: partner_payout_holding';\n  END IF;\n\n  /*\n    Step 2: write ledger transaction + entries.\n    Nếu fail ở đây, cả version bump lẫn balance update đều rollback.\n  */\n  INSERT INTO ledger_transactions (\n    transaction_id,\n    transaction_type,\n    status,\n    effective_at,\n    created_at,\n    reference_type,\n    reference_id\n  )\n  VALUES (\n    v_tx_id,\n    'cash_out_hold',\n    'pending',\n    NOW(),\n    NOW(),\n    'payment_order',\n    'po_1001'\n  );\n\n  INSERT INTO ledger_entries (\n    entry_id,\n    transaction_id,\n    account_id,\n    direction,\n    status,\n    amount,\n    currency,\n    effective_at,\n    created_at\n  )\n  VALUES\n    (\n      v_entry_debit_id,\n      v_tx_id,\n      'alice_wallet',\n      'debit',\n      'pending',\n      70,\n      'USD',\n      NOW(),\n      NOW()\n    ),\n    (\n      v_entry_credit_id,\n      v_tx_id,\n      'partner_payout_holding',\n      'credit',\n      'pending',\n      70,\n      'USD',\n      NOW(),\n      NOW()\n    );\n\nEND $$;\n\nCOMMIT;\n",
