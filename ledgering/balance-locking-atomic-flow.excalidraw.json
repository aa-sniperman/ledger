      "updated": 1773627840848,
      "link": null,
      "locked": false,
      "text": "BEGIN;\n\nDO $$\nDECLARE\n  v_tx_id text := 'tx_hold_1001';\n  v_entry_debit_id text := 'entry_hold_1001_debit';\n  v_entry_credit_id text := 'entry_hold_1001_credit';\nBEGIN\n  /*\n    Source account: alice_wallet\n    credit_normal\n    available_before = pending_credits - pending_debits\n                     = 100 - 10\n                     = 90\n    reserve amount = 70\n    => allowed\n  */\n  UPDATE account_current_balances cb\n  SET\n    pending_debits = cb.pending_debits + 70,\n    current_version = cb.current_version + 1,\n    updated_at = NOW()\n  FROM accounts a\n  WHERE cb.account_id = 'alice_wallet'\n    AND a.account_id = cb.account_id\n    AND a.normal_balance = 'credit_normal'\n    AND (cb.posted_credits - cb.pending_debits) >= 70;\n\n  IF NOT FOUND THEN\n    RAISE EXCEPTION\n      'balance_lock_failed: alice_wallet does not have 70 USD available';\n  END IF;\n\n  /*\n    Counterparty account for the hold.\n    Ví dụ: cash_out_holding cũng là liability-style holding account,\n    nên reserve được phản ánh bằng pending_credit bên đối ứng.\n  */\n  UPDATE account_current_balances\n  SET\n    pending_credits = pending_credits + 70,\n    current_version = current_version + 1,\n    updated_at = NOW()\n  WHERE account_id = 'partner_payout_holding';\n\n  IF NOT FOUND THEN\n    RAISE EXCEPTION\n      'missing_balance_row: partner_payout_holding';\n  END IF;\n\n  INSERT INTO ledger_transactions (\n    transaction_id,\n    transaction_type,\n    status,\n    effective_at,\n    created_at,\n    reference_type,\n    reference_id\n  )\n  VALUES (\n    v_tx_id,\n    'cash_out_hold',\n    'pending',\n    NOW(),\n    NOW(),\n    'payment_order',\n    'po_1001'\n  );\n\n  INSERT INTO ledger_entries (\n    entry_id,\n    transaction_id,\n    account_id,\n    direction,\n    status,\n    amount,\n    currency,\n    effective_at,\n    created_at\n  )\n  VALUES\n    (\n      v_entry_debit_id,\n      v_tx_id,\n      'alice_wallet',\n      'debit',\n      'pending',\n      70,\n      'USD',\n      NOW(),\n      NOW()\n    ),\n    (\n      v_entry_credit_id,\n      v_tx_id,\n      'partner_payout_holding',\n      'credit',\n      'pending',\n      70,\n      'USD',\n      NOW(),\n      NOW()\n    );\n\nEND $$;\n\nCOMMIT;\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "BEGIN;\n\nDO $$\nDECLARE\n  v_tx_id text := 'tx_hold_1001';\n  v_entry_debit_id text := 'entry_hold_1001_debit';\n  v_entry_credit_id text := 'entry_hold_1001_credit';\nBEGIN\n  /*\n    Source account: alice_wallet\n    credit_normal\n    available_before = pending_credits - pending_debits\n                     = 100 - 10\n                     = 90\n    reserve amount = 70\n    => allowed\n  */\n  UPDATE account_current_balances cb\n  SET\n    pending_debits = cb.pending_debits + 70,\n    current_version = cb.current_version + 1,\n    updated_at = NOW()\n  FROM accounts a\n  WHERE cb.account_id = 'alice_wallet'\n    AND a.account_id = cb.account_id\n    AND a.normal_balance = 'credit_normal'\n    AND (cb.posted_credits - cb.pending_debits) >= 70;\n\n  IF NOT FOUND THEN\n    RAISE EXCEPTION\n      'balance_lock_failed: alice_wallet does not have 70 USD available';\n  END IF;\n\n  /*\n    Counterparty account for the hold.\n    Ví dụ: cash_out_holding cũng là liability-style holding account,\n    nên reserve được phản ánh bằng pending_credit bên đối ứng.\n  */\n  UPDATE account_current_balances\n  SET\n    pending_credits = pending_credits + 70,\n    current_version = current_version + 1,\n    updated_at = NOW()\n  WHERE account_id = 'partner_payout_holding';\n\n  IF NOT FOUND THEN\n    RAISE EXCEPTION\n      'missing_balance_row: partner_payout_holding';\n  END IF;\n\n  INSERT INTO ledger_transactions (\n    transaction_id,\n    transaction_type,\n    status,\n    effective_at,\n    created_at,\n    reference_type,\n    reference_id\n  )\n  VALUES (\n    v_tx_id,\n    'cash_out_hold',\n    'pending',\n    NOW(),\n    NOW(),\n    'payment_order',\n    'po_1001'\n  );\n\n  INSERT INTO ledger_entries (\n    entry_id,\n    transaction_id,\n    account_id,\n    direction,\n    status,\n    amount,\n    currency,\n    effective_at,\n    created_at\n  )\n  VALUES\n    (\n      v_entry_debit_id,\n      v_tx_id,\n      'alice_wallet',\n      'debit',\n      'pending',\n      70,\n      'USD',\n      NOW(),\n      NOW()\n    ),\n    (\n      v_entry_credit_id,\n      v_tx_id,\n      'partner_payout_holding',\n      'credit',\n      'pending',\n      70,\n      'USD',\n      NOW(),\n      NOW()\n    );\n\nEND $$;\n\nCOMMIT;\n",
