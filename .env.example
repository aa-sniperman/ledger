APP_ENV=development
HTTP_ADDR=:8080

# Central command/status database.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ledger_central?sslmode=disable

# Central test database used by integration tests.
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/ledger_test?sslmode=disable

# All known shards in this environment.
SHARD_IDS=shard-a,shard-b

# Shard-local system account pool sizes by role.
# Higher pool sizes reduce hot-row contention for those roles.
SYSTEM_ACCOUNT_POOL_SIZES=payout_holding=4,cash_in_clearing=4

# Optional worker shard subset.
# Leave empty to let a worker own all shards in SHARD_IDS.
# Example:
# WORKER_SHARD_IDS=shard-a
WORKER_SHARD_IDS=

# Ledger shard databases.
SHARD_DATABASE_URLS=shard-a=postgres://postgres:postgres@localhost:5432/ledger_shard_a?sslmode=disable,shard-b=postgres://postgres:postgres@localhost:5432/ledger_shard_b?sslmode=disable

# Test shard databases used by multi-shard integration tests.
TEST_SHARD_DATABASE_URLS=shard-a=postgres://postgres:postgres@localhost:5432/ledger_shard_a_test?sslmode=disable,shard-b=postgres://postgres:postgres@localhost:5432/ledger_shard_b_test?sslmode=disable

SHUTDOWN_TIMEOUT=10s
HTTP_READ_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=10s
WORKER_POLL_INTERVAL=250ms

# Best-effort API-side idempotency fast path.
# Set to 0s to disable.
API_IDEMPOTENCY_CACHE_TTL=5m

# Development-only debug routes such as /debug/devsetup/seed.
DEBUG_API_ENABLED=true

# Kafka command delivery.
KAFKA_ENABLED=true
KAFKA_BROKERS=localhost:9092
KAFKA_COMMANDS_TOPIC=ledger.commands
KAFKA_CONSUMER_GROUP=ledger-worker
KAFKA_AUTO_CREATE_TOPIC=false
KAFKA_TOPIC_PARTITIONS=2
KAFKA_REPLICATION_FACTOR=1
